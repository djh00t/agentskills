{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecKitAgentRequest",
  "type": "object",
  "required": ["spec_title", "spec_body"],
  "properties": {
    "spec_title": {
      "type": "string",
      "minLength": 1
    },
    "spec_body": {
      "type": "string",
      "minLength": 1
    },
    "request_type": {
      "type": "string",
      "enum": [
        "new-feature",
        "behavior-change"
      ],
      "default": "new-feature"
    },
    "project_dir": {
      "type": "string",
      "minLength": 1,
      "default": "."
    },
    "ai_assistant": {
      "type": "string",
      "minLength": 1,
      "default": "codex"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "workflow.schema.json#/$defs/task"
      }
    },
    "dry_run": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": false
}
