{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecKitWorkflow",
  "type": "object",
  "$defs": {
    "task": {
      "type": "object",
      "required": ["task_id", "title", "depends_on", "parallelizable"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "parallelizable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "additionalProperties": false
}
